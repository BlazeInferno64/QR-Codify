  <div class="modal fade" id="generateModal" tabindex="-1" aria-labelledby="generateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
      <div class="modal-content border-0 shadow-lg"
        style="background: linear-gradient(145deg, #0f172a, #111827); color: #e2e8f0; border-radius: 20px;">
        <div class="modal-header border-secondary-subtle px-3 py-3">
          <div>
            <h5 class="modal-title fw-bold text-white" id="generateModalLabel">Generate a QR Code</h5>
            <p class="small mb-0" style="color: rgba(226,232,240,0.45);">Customize and preview in real-time.</p>
          </div>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body p-3">
          <div class="row g-3">
            <div class="col-md-7 order-2 order-md-1">
              <div class="mini-card p-3 mb-2.5">
                <label for="generateText" class="form-label small text-white fw-semibold">Text / URL to encode</label>
                <textarea id="generateText" class="form-control" rows="3" placeholder="https://example.com"></textarea>
              </div>
              <div class="mini-card p-3 mb-2.5">
                <label for="generateTheme" class="form-label small text-white fw-semibold">Visual Theme</label>
                <select id="generateTheme" class="form-select">
                  <option value="">Default (Modern Mono)</option>
                  <option value="cyber">Cyber Gradient</option>
                  <option value="tokyonight">Tokyo Night</option>
                  <option value="neon">Neon Lime</option>
                  <option value="glitch">Glitch Matrix</option>
                </select>
              </div>
              <div class="mini-card p-3">
                <label for="generateSize" class="form-label small text-white fw-semibold">Resolution (px) (500
                  recommended)</label>
                <input type="number" id="generateSize" class="form-control" value="500" min="100" max="1000" />
              </div>
            </div>

            <div class="col-md-5 order-1 order-md-2 d-flex flex-column align-items-center justify-content-center py-2">
              <div class="qr-box text-center mb-2 mx-auto" style="max-width: 180px; padding: 12px;">
                <img id="modalQrPreview" src="/api/generate?data=QR%20Codify" alt="QR Preview" class="img-fluid" />
              </div>
              <p class="small mb-0 text-muted" style="font-size: 0.72rem;">Live Preview</p>
            </div>
          </div>
        </div>

        <div class="modal-footer border-secondary-subtle p-3">
