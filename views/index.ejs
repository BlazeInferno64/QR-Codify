<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="shortcut icon" href="/logo" type="image/x-icon">
  <title>QR Codify — Free, Open Source QR Code Generator & Scanner</title>
  <meta name="description"
    content="Generate and scan QR codes instantly. No data stored, 100% free and open source. Themed QR codes with a clean REST API for developers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
  <style>
    :root {
      color-scheme: dark;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
    }

    body {
      overflow-x: hidden;
      background:
        radial-gradient(ellipse 80% 40% at 50% -5%, rgba(99, 102, 241, 0.18), transparent),
        linear-gradient(160deg, #030810 0%, #060e1c 55%, #020611 100%);
      color: #e2e8f0;
      font-family: "Geist Mono", "Segoe UI", Arial, sans-serif;
    }

    .material-symbols-outlined {
      font-family: 'Material Symbols Outlined';
      display: inline-flex;
      align-items: center;
      justify-content: center;
      vertical-align: middle;
      line-height: 1;
    }

    /* Ambient orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(90px);
      z-index: -1;
      pointer-events: none;
      animation: orbFloat 12s ease-in-out infinite;
    }

    .orb-1 {
      width: 260px;
      height: 260px;
      top: -50px;
      right: -50px;
      background: #8b5cf6;
      opacity: 0.08;
    }

    .orb-2 {
      width: 200px;
      height: 200px;
      bottom: -50px;
      left: -50px;
      background: #22d3ee;
      opacity: 0.06;
      animation-delay: -5s;
    }

    .orb-3 {
      width: 150px;
      height: 150px;
      top: 45%;
      left: 45%;
      background: #6366f1;
      opacity: 0.04;
      animation-delay: -2.5s;
    }

    @media(min-width: 768px) {
      .orb-1 {
        width: 380px;
        height: 380px;
        top: -100px;
        right: -100px;
        opacity: 0.12;
      }

      .orb-2 {
        width: 280px;
        height: 280px;
        bottom: -80px;
        left: -80px;
        opacity: 0.10;
      }

      .orb-3 {
        width: 220px;
        height: 220px;
      }
    }

    @keyframes orbFloat {

      0%,
      100% {
        transform: translateY(0) scale(1);
      }

      50% {
        transform: translateY(-20px) scale(1.04);
      }
    }

    /* Animations */
    .fade-up {
      opacity: 0;
      transform: translateY(22px);
      animation: rise 0.7s cubic-bezier(.22, .68, 0, 1.1) forwards;
    }

    .delay-1 {
      animation-delay: .08s;
    }

    .delay-2 {
      animation-delay: .16s;
    }

    .delay-3 {
      animation-delay: .24s;
    }

    .delay-4 {
      animation-delay: .32s;
    }

    .delay-5 {
      animation-delay: .40s;
    }

    .delay-6 {
      animation-delay: .50s;
    }

    @keyframes rise {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Cards */
    .glass-card {
      background: rgba(15, 23, 42, 0.78);
      border: 1px solid rgba(148, 163, 184, 0.16);
      border-radius: 20px;
      backdrop-filter: blur(14px);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
      transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
    }

    @media(min-width: 768px) {
      .glass-card {
        border-radius: 24px;
        box-shadow: 0 20px 56px rgba(0, 0, 0, 0.38);
      }
    }

    .glass-card:hover {
      transform: translateY(-2px);
      border-color: rgba(129, 140, 248, 0.38);
      box-shadow: 0 24px 52px rgba(99, 102, 241, 0.14);
    }

    .mini-card {
      border: 1px solid rgba(148, 163, 184, 0.16);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.70);
      transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
    }

    .mini-card:hover {
      transform: translateY(-2px);
      border-color: rgba(129, 140, 248, 0.36);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.12);
    }

    /* Trust pills */
    .trust-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: .03em;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid;
      white-space: nowrap;
    }

    @media(min-width: 576px) {
      .trust-pill {
        font-size: 0.72rem;
        padding: 5px 13px;
      }
    }

    .tp-green {
      background: rgba(34, 197, 94, 0.10);
      border-color: rgba(34, 197, 94, 0.28);
      color: #4ade80;
    }

    .tp-violet {
      background: rgba(139, 92, 246, 0.10);
      border-color: rgba(139, 92, 246, 0.28);
      color: #a78bfa;
    }

    .tp-cyan {
      background: rgba(34, 211, 238, 0.10);
      border-color: rgba(34, 211, 238, 0.28);
      color: #67e8f9;
    }

    .tp-amber {
      background: rgba(251, 191, 36, 0.10);
      border-color: rgba(251, 191, 36, 0.28);
      color: #fcd34d;
    }

    .tp-pink {
      background: rgba(236, 72, 153, 0.10);
      border-color: rgba(236, 72, 153, 0.28);
      color: #f472b6;
    }

    .tp-red {
      background: rgba(255, 0, 85, 0.10);
      border-color: rgba(255, 0, 85, 0.28);
      color: #ff4d88;
    }

    /* Eyebrow labels */
    .eyebrow {
      font-size: .66rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: #67e8f9;
      margin-bottom: 10px;
    }

    /* Gradient text */
    .grad-text {
      background: linear-gradient(90deg, #818cf8, #67e8f9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Badge pill */
    .soft-pill {
      background: rgba(99, 102, 241, 0.12);
      border: 1px solid rgba(99, 102, 241, 0.26);
      color: #a5b4fc;
      font-size: .68rem;
      letter-spacing: .07em;
      text-transform: uppercase;
    }

    /* Buttons */
    .btn-primary-custom {
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border: none;
      color: #fff;
      box-shadow: 0 8px 20px rgba(99, 102, 241, 0.30);
      transition: filter 160ms, box-shadow 160ms, transform 120ms;
    }

    .btn-primary-custom:hover {
      filter: brightness(1.09);
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 12px 28px rgba(99, 102, 241, 0.42);
    }

    .btn-primary-custom:active {
      transform: translateY(0);
    }

    /* Stat numbers */
    .stat-num {
      font-size: 1.8rem;
      font-weight: 900;
      line-height: 1;
      background: linear-gradient(135deg, #a5b4fc, #67e8f9);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    @media(min-width: 768px) {
      .stat-num {
        font-size: 2.2rem;
      }
    }

    /* Method badges */
    .method {
      font-size: .64rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 6px;
      margin-right: 6px;
      flex-shrink: 0;
    }

    .m-get {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
    }

    .m-post {
      background: rgba(99, 102, 241, 0.18);
      color: #a5b4fc;
    }

    /* Feature icon box */
    .feat-icon {
      width: 46px;
      height: 46px;
      border-radius: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      margin-bottom: 14px;
      flex-shrink: 0;
    }

    /* QR preview box */
    .qr-box {
      background: linear-gradient(135deg, #0c1222, #111827);
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 16px;
      padding: 16px;
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .qr-box img {
      border-radius: 10px;
      display: block;
      margin: auto;
      width: 100%;
      height: auto;
      max-width: 100%;
    }

    /* Theme dot */
    .tdot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
    }

    .sdiv {
      border: none;
      border-top: 1px solid rgba(148, 163, 184, 0.12);
      margin: 0;
    }

    .privacy-icon {
      font-size: 1.75rem;
      margin-bottom: 6px;
    }

    /* Forms */
    .form-control,
    .form-select {
      background: rgba(15, 23, 42, 0.65) !important;
      border: 1px solid rgba(148, 163, 184, 0.26) !important;
      color: #e2e8f0 !important;
      border-radius: 10px !important;
    }

    .form-control::placeholder {
      color: rgba(226, 232, 240, 0.38);
    }

    .form-control:focus,
    .form-select:focus {
      border-color: #6366f1 !important;
      box-shadow: 0 0 0 .2rem rgba(99, 102, 241, 0.2) !important;
    }

    .form-select option {
      background: #0f172a;
    }

    footer {
      border-top: 1px solid rgba(148, 163, 184, 0.12);
    }

    footer a {
      transition: color 150ms;
    }

    footer a:hover {
      color: #a5b4fc !important;
    }

    .btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1px;
    }

    /* ── MOBILE RESPONSIVE MODAL OPTIMIZATIONS ── */
    @media (max-width: 576px) {
      .modal-dialog.modal-fullscreen-sm-down {
        margin: 0;
        max-width: 100%;
      }

      .modal-dialog.modal-fullscreen-sm-down .modal-content {
        border-radius: 0 !important;
        min-height: 100vh;
      }

      .modal-body {
        padding: 1rem !important;
      }

      .modal-header .modal-title {
        font-size: 1.15rem !important;
      }
    }

    /* Code highlights scroll isolation wrapper */
    .api-code-wrapper {
      position: relative;
      width: 100%;
      background: #090d16;
      border-radius: 10px;
      overflow: hidden;
    }

    .api-code-wrapper pre {
      margin: 0 !important;
      padding: 12px !important;
      overflow-x: auto !important;
      white-space: pre !important;
      word-break: normal !important;
      word-wrap: normal !important;
      -webkit-overflow-scrolling: touch;
      max-height: 320px;
    }

    .api-code-wrapper code {
      font-size: 0.75rem !important;
      line-height: 1.5 !important;
      font-family: "Geist Mono", monospace !important;
    }

    /* Custom safe styling constraints for scan results */
    #scanResult {
      font-size: 0.78rem;
      max-height: 160px;
      overflow-y: auto;
      white-space: pre-wrap;
      word-break: break-all;
      background: rgba(0, 0, 0, 0.2);
      padding: 10px;
      border-radius: 8px;
      font-family: "Geist Mono", monospace;
      color: rgba(226, 232, 240, 0.7);
    }

    @media(prefers-reduced-motion:reduce) {

      *,
      *::before,
      *::after {
        animation: none !important;
        transition: none !important;
      }
    }
  </style>
</head>

<body>

  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <main class="container py-3 py-md-5">

    <section class="glass-card p-3 p-sm-4 p-md-5 mb-4 fade-up">
      <div class="row align-items-center g-4">
        <div class="col-lg-7 text-center text-lg-start">
          <span class="soft-pill badge rounded-pill px-3 py-2 mb-3 d-inline-block">
            Free &nbsp;·&nbsp; Open Source &nbsp;·&nbsp; No Sign-up
          </span>
          <h1 class="display-6 display-md-5 fw-bold text-white mb-3 lh-sm">
            QR codes done right<br>
            <span class="grad-text">fast, private and free!</span>
          </h1>
          <p class="mb-4 small-text" style="color:rgba(226,232,240,0.72); font-size:1rem; line-height:1.6;">
            Generate styled QR codes and decode images in seconds. No sign-up, no tracking, no data retention — your
            content is processed in memory and discarded the moment the image is sent back to you.
          </p>

          <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-2 mb-4">
            <span class="trust-pill tp-green">🔒 Zero data stored</span>
            <span class="trust-pill tp-violet">⚡ Instant generation</span>
            <span class="trust-pill tp-cyan">🌐 REST API included</span>
            <span class="trust-pill tp-amber">🆓 100% free forever</span>
            <span class="trust-pill tp-pink">🔓 Open source</span>
          </div>

          <div
            class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-2.5 gap-sm-3 mb-4">
            <button type="button" class="btn btn-primary-custom btn-lg px-4 py-2.5 fw-semibold w-100 w-sm-auto"
              data-bs-toggle="modal" data-bs-target="#generateModal">
              <i class="material-symbols-outlined">qr_code_2</i> Generate QR
            </button>
            <br>
            <button type="button" class="btn btn-outline-light btn-lg px-4 py-2.5 w-100 w-sm-auto"
              data-bs-toggle="modal" data-bs-target="#scanModal">
              <i class="material-symbols-outlined">qr_code_scanner</i> Scan QR
            </button>
            <br>
            <button id="openApiExampleBtn" type="button" class="btn btn-lg px-4 py-2.5 w-100 w-sm-auto"
              style="color:#67e8f9;border:1px solid rgba(34,211,238,0.35);background:rgba(34,211,238,0.06);">
              <i class="material-symbols-outlined">api</i>
              API
              Example</button>
          </div>

          <ul class="list-unstyled small mb-0 text-start d-inline-block text-lg-start"
            style="color:rgba(226,232,240,0.55);">
            <li class="mb-1"><span style="color:#4ade80;">✓</span>&nbsp; No account, no email — just open and use</li>
            <li class="mb-1"><span style="color:#4ade80;">✓</span>&nbsp; <%- themeWord %> premium visual themes: Cyber,
                Tokyo Night, Neon Lime, Glitch Matrix</li>
            <li class="mb-1"><span style="color:#4ade80;">✓</span>&nbsp; Developer API — one request returns a PNG</li>
            <li class="mb-0"><span style="color:#4ade80;">✓</span>&nbsp; Full source on GitHub — inspect, fork,
              self-host</li>
          </ul>
        </div>

        <div class="col-lg-5">
          <div class="mini-card p-3 p-sm-4 text-center">
            <div class="eyebrow text-center">Live Preview</div>
            <div class="qr-box mb-3 mx-auto" style="max-width: 320px;">
              <img
                src="/api/generate?data=QR%20Codify%20%E2%80%94%20made%20with%20%E2%9D%A4%EF%B8%8F%20by%20BlazeInferno64.%20Visit%3A%20https%3A%2F%2Fgithub.com%2Fblazeinferno64%2FQR-Codify&theme=<%- previewTheme  %>&size=500x500"
                alt="QR code preview" class="img-fluid" />
            </div>
            <div class="d-flex justify-content-center gap-2 flex-wrap">
              <span class="trust-pill tp-cyan" style="font-size:.67rem;">
                <span class="tdot" style="background:linear-gradient(135deg,#3b82f6,#ec4899);"></span>Cyber
              </span>
              <span class="trust-pill tp-violet" style="font-size:.67rem;">
                <span class="tdot" style="background:linear-gradient(135deg,#7aa2f7,#f7768e);"></span>Tokyo Night
              </span>
              <span class="trust-pill tp-green" style="font-size:.67rem;">
                <span class="tdot" style="background:linear-gradient(180deg,#00ffcc,#99ff00);"></span>Neon
              </span>
              <span class="trust-pill tp-red" style="font-size:.67rem;">
                <span class="tdot" style="background:linear-gradient(180deg,#ff0055,#00ffaa);"></span>Glitch
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="glass-card p-3 p-sm-4 mb-4 fade-up delay-1">
      <div class="row g-3 text-center">
        <div class="col-6 col-md-3">
          <div class="stat-num">0</div>
          <div class="small mt-1 mt-sm-2" style="color:rgba(226,232,240,0.5); font-size: 0.78rem;">bytes of user<br>data
            stored</div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-num"><%- themeNum %></div>
          <div class="small mt-1 mt-sm-2" style="color:rgba(226,232,240,0.5); font-size: 0.78rem;">premium
            visual<br>themes</div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-num">1</div>
          <div class="small mt-1 mt-sm-2" style="color:rgba(226,232,240,0.5); font-size: 0.78rem;">API call to get<br>a
            QR image</div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-num">∞</div>
          <div class="small mt-1 mt-sm-2" style="color:rgba(226,232,240,0.5); font-size: 0.78rem;">free forever,<br>no
            rate-wall</div>
        </div>
      </div>
    </section>

    <section class="mb-4">
      <div class="eyebrow text-center fade-up delay-1">Why QR Codify</div>
      <div class="row g-3">
        <article class="col-md-6 col-xl-3 fade-up delay-1">
          <div class="mini-card p-4 h-100">
            <div class="feat-icon" style="background:rgba(99,102,241,0.13);">🔒</div>
            <h2 class="h6 fw-bold text-white mb-2">Private by design</h2>
            <p class="small mb-0" style="color:rgba(226,232,240,0.58);line-height:1.65;">Your URLs and text are
              processed in-memory and discarded immediately. Nothing is logged, stored, or sold. Ever.</p>
          </div>
        </article>
        <article class="col-md-6 col-xl-3 fade-up delay-2">
          <div class="mini-card p-4 h-100">
            <div class="feat-icon" style="background:rgba(34,211,238,0.10);">⚡</div>
            <h2 class="h6 fw-bold text-white mb-2">Instant generation</h2>
            <p class="small mb-0" style="color:rgba(226,232,240,0.58);line-height:1.65;">Server-side canvas rendering
              delivers a crisp PNG in milliseconds — no third-party QR service, no redirects.</p>
          </div>
        </article>
        <article class="col-md-6 col-xl-3 fade-up delay-3">
          <div class="mini-card p-4 h-100">
            <div class="feat-icon" style="background:rgba(139,92,246,0.12);">🎨</div>
            <h2 class="h6 fw-bold text-white mb-2">Themed visuals</h2>
            <p class="small mb-0" style="color:rgba(226,232,240,0.58);line-height:1.65;">Cyber gradient, Tokyo Night,
              Neon Lime and Glitch Matrix — custom finder patterns and gradient fills that actually look good.</p>
          </div>
        </article>
        <article class="col-md-6 col-xl-3 fade-up delay-4">
          <div class="mini-card p-4 h-100">
            <div class="feat-icon" style="background:rgba(34,197,94,0.10);">🛠️</div>
            <h2 class="h6 fw-bold text-white mb-2">Developer First API</h2>
            <p class="small mb-0" style="color:rgba(226,232,240,0.58);line-height:1.65;">One GET or POST to <code
                style="color:#a5b4fc;">/api/generate</code> returns a PNG. Pass <code
                style="color:#a5b4fc;">data</code>, <code style="color:#a5b4fc;">theme</code>, <code
                style="color:#a5b4fc;">size</code> — done.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="glass-card p-3 p-sm-4 p-md-5 mb-4 fade-up delay-2">
      <div class="row align-items-center g-4">
        <div class="col-lg-6 text-center text-lg-start">
          <div class="eyebrow">Privacy Promise</div>
          <h2 class="h3 fw-bold text-white mb-3">We see nothing.<br>We store nothing.</h2>
          <p style="color:rgba(226,232,240,0.65);line-height:1.7;" class="mb-3 small-text">
            When you generate a QR code, your input passes directly into the rendering engine and is discarded the
            instant the image is sent back. There is no database, no analytics pipeline, no session cookie, and no user
            account.
          </p>
          <p style="color:rgba(226,232,240,0.65);line-height:1.7;" class="mb-0 small-text">
            You can verify this yourself — the full source is on GitHub. Self-hosting takes a single <code
              style="color:#67e8f9;">node .</code> command.
          </p>
        </div>
        <div class="col-lg-6">
          <div class="row g-2 g-sm-3">
            <div class="col-6">
              <div class="mini-card p-2.5 p-sm-3 text-center h-100">
                <div class="privacy-icon">🚫</div>
                <div class="small fw-bold text-white mb-1" style="font-size:0.8rem;">No tracking</div>
                <div class="small" style="color:rgba(226,232,240,0.48); font-size:0.7rem;">No analytics or
                  fingerprinting</div>
              </div>
            </div>
            <div class="col-6">
              <div class="mini-card p-2.5 p-sm-3 text-center h-100">
                <div class="privacy-icon">🗄️</div>
                <div class="small fw-bold text-white mb-1" style="font-size:0.8rem;">No database</div>
                <div class="small" style="color:rgba(226,232,240,0.48); font-size:0.7rem;">Pure stateless API, zero
                  persistence</div>
              </div>
            </div>
            <div class="col-6">
              <div class="mini-card p-2.5 p-sm-3 text-center h-100">
