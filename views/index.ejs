  <div class="modal fade" id="scanModal" tabindex="-1" aria-labelledby="scanModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
      <div class="modal-content border-0 shadow-lg"
        style="background: linear-gradient(145deg, #0f172a, #111827); color: #e2e8f0; border-radius: 20px;">
        <div class="modal-header border-secondary-subtle px-3 py-3">
          <div>
            <h5 class="modal-title fw-bold text-white" id="scanModalLabel">Scan / Decode QR Code</h5>
            <p class="small mb-0" style="color: rgba(226,232,240,0.45);">Upload local images to decrypt content
              instantly.</p>
          </div>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body p-3">
          <div class="mini-card p-3 mb-3">
            <label class="fw-semibold mb-2 small text-white">Upload Image File</label>
            <input id="scanFileInput" type="file" accept="image/*" class="form-control" />
          </div>
          <div class="mini-card p-3">
            <h6 class="fw-semibold mb-2 small text-white">Decoded Contents</h6>
            <pre id="scanResult">Waiting for target selection...</pre>
          </div>
        </div>

        <div class="modal-footer border-secondary-subtle p-3 d-flex flex-row gap-2">
          <button type="button" class="btn btn-outline-light flex-fill" data-bs-dismiss="modal">Close</button>
          <button id="decodeUploadBtn" type="button"
            class="btn btn-primary-custom text-white fw-semibold flex-fill">Decode Image</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.getElementById('updatePreviewBtn')?.addEventListener('click', updateModalPreview);
      document.getElementById('decodeUploadBtn')?.addEventListener('click', scanUploadedFile);

      function openApiModal() {
        renderFetchExample();
        new bootstrap.Modal(document.getElementById('apiExampleModal')).show();
      }
      document.getElementById('openApiExampleBtn')?.addEventListener('click', openApiModal);
      document.getElementById('openApiExampleBtn2')?.addEventListener('click', openApiModal);
      document.getElementById('openJoltBtn')?.addEventListener('click', openExampleInJolt);
    });

    function updateModalPreview() {
      const text = document.getElementById('generateText').value.trim() || 'QR Codify';
      const theme = document.getElementById('generateTheme').value;
      const size = document.getElementById('generateSize').value || 500;
      let url = `/api/generate?data=${encodeURIComponent(text)}&size=${size}x${size}`;
      if (theme) url += `&theme=${theme}`;
      document.getElementById('modalQrPreview').src = url;
      document.getElementById('downloadQrBtn').href = url;
    }

    function renderFetchExample() {
      const code = `// REST API — no auth, no SDK needed
// Rate limit: 45 requests/min per IP

const response = await fetch('${window.location.origin}/api/generate', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    data: 'Powered by QR Codify. Visit - ${window.location.origin} for more info!', // Replace with your desired data
    theme: 'cyber',  // 'cyber' | 'tokyonight' | 'neon'
    size: 600,       // pixels, 100–1000
    // banner: 'data:image/png;base64,<your_base64_here>'
  })
});
const imageBlob = await response.blob();
const imageUrl = URL.createObjectURL(imageBlob);
console.log('QR code URL:', imageUrl);
window.open(imageUrl);`;

      const target = document.getElementById('fetchExampleCode');
      if (target) {
        target.textContent = code;
        if (window.Prism) Prism.highlightElement(target);
      }
    }

    function openExampleInJolt() {
      const code = document.getElementById('fetchExampleCode')?.textContent || '';
      const joltUrl = `http://blazeinferno64.github.io/jolt.html?code=${encodeURIComponent(code)}&run=true`;
      window.open(joltUrl, '_blank', 'noopener,noreferrer');
    }

    async function scanUploadedFile() {
      const input = document.getElementById('scanFileInput');
      const resultBox = document.getElementById('scanResult');
      if (!input?.files[0]) return alert('Select an image first.');
      const reader = new FileReader();
      reader.onload = async () => {
        resultBox.textContent = 'Analyzing...';
        try {
          const response = await fetch('/api/read', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: reader.result })
          });
          const data = await response.json();
          resultBox.textContent = JSON.stringify(data, null, 2);
        } catch (e) {
          resultBox.textContent = 'Error decoding image.';
        }
      };
      reader.readAsDataURL(input.files[0]);
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-javascript.min.js"></script>
