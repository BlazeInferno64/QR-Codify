              <button type="button" class="btn btn-outline-light w-100" data-bs-dismiss="modal">Close</button>
            </div>
            <div class="col-12 col-sm-4 p-0 px-1 order-1 order-sm-2">
              <button id="updatePreviewBtn" type="button"
                class="btn btn-primary-custom w-100 fw-semibold">Update</button>
            </div>
            <div class="col-12 col-sm-4 p-0 px-1 order-2 order-sm-3">
              <a id="downloadQrBtn" href="/api/generate?data=QR%20Codify" download="qrcode.png"
                class="btn btn-success w-100 text-white fw-semibold">Download</a>
            </div>
          </div>
        </div>
      </div>
